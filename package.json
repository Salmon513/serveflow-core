{
  "name": "serveflow-core",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build:shared": "pnpm --filter @serveflow/shared build",
    "build:backend": "pnpm --filter @serveflow/backend build",
    "build:frontend": "pnpm --filter @serveflow/frontend build",
    "build": "pnpm build:shared && pnpm build:backend && pnpm build:frontend",
    "typecheck": "pnpm build:shared && pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "sharp"]
  }
}
